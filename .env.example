# Copy this file to .env and fill in real values before running docker-compose

# ── PostgreSQL ──────────────────────────────────────────
DB_PASS=StrongPasswordHere123!

# ── JWT ─────────────────────────────────────────────────
# Must be at least 32 characters (256-bit key)
JWT_SECRET=Replace-This-With-A-Real-Secret-Minimum-32-Characters

# JWT expiry in milliseconds  (86400000 = 24 hours)
JWT_EXPIRY_MS=86400000
